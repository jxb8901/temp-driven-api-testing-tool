{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:att:schema:dbhelper:v2.5",
  "type": "object",
  "required": ["schemaVersion", "id", "name", "description", "connection"],
  "properties": {
    "schemaVersion": {"const": "att-dbhelper/v2.5"},
    "id": {"type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_-]*$"},
    "name": {"type": "string", "minLength": 1},
    "description": {"type": "string", "minLength": 1},
    "connection": {"$ref": "#/$defs/connection"},
    "statement": {"$ref": "#/$defs/statement"},
    "transaction": {"$ref": "#/$defs/transaction"},
    "result": {"$ref": "#/$defs/result"},
    "evidence": {"$ref": "#/$defs/evidence"}
  },
  "patternProperties": {"^x-": {}},
  "additionalProperties": false,
  "$defs": {
    "connection": {
      "type": "object",
      "required": ["url"],
      "properties": {
        "url": {"type": "string", "minLength": 1},
        "username": {"type": "string"},
        "password": {"type": "string"},
        "driverClass": {"type": "string", "minLength": 1},
        "properties": {"type": "object", "additionalProperties": {"type": "string"}},
        "readOnly": {"type": "boolean"},
        "isolation": {"enum": ["driverDefault", "readUncommitted", "readCommitted", "repeatableRead", "serializable"]}
      },
      "patternProperties": {"^x-": {}},
      "additionalProperties": false
    },
    "statement": {
      "type": "object",
      "properties": {"timeoutSeconds": {"type": "integer", "minimum": 1, "maximum": 3600}},
      "patternProperties": {"^x-": {}},
      "additionalProperties": false
    },
    "transaction": {
      "type": "object",
      "properties": {
        "scope": {"enum": ["case", "statement"]},
        "onEnd": {"enum": ["commit", "rollback"]}
      },
      "patternProperties": {"^x-": {}},
      "additionalProperties": false
    },
    "result": {
      "type": "object",
      "properties": {
        "maxRows": {"type": "integer", "minimum": 1, "maximum": 1000000},
        "maxCellBytes": {"type": "integer", "minimum": 1, "maximum": 1073741824},
        "maxBytes": {"type": "integer", "minimum": 1, "maximum": 1073741824}
      },
      "patternProperties": {"^x-": {}},
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "properties": {
        "sql": {"enum": ["full", "hash"]},
        "parameters": {"enum": ["masked", "types", "values"]}
      },
      "patternProperties": {"^x-": {}},
      "additionalProperties": false
    }
  }
}
