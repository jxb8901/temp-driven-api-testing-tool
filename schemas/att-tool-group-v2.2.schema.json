{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:att:schema:tool-group:v2.2",
  "type": "object",
  "required": ["schemaVersion", "id", "name", "description", "tools"],
  "properties": {
    "schemaVersion": {"const": "att-tool-group/v2.2"},
    "id": {"type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_-]*$"},
    "name": {"type": "string", "minLength": 1},
    "description": {"type": "string", "minLength": 1},
    "script": {"$ref": "#/$defs/command"},
    "ssh": {"$ref": "#/$defs/ssh"},
    "tools": {"type": "object", "minProperties": 1, "propertyNames": {"pattern": "^[A-Za-z_][A-Za-z0-9_-]*$"}, "additionalProperties": {"$ref": "#/$defs/tool"}}
  },
  "patternProperties": {"^x-": {}},
  "additionalProperties": false,
  "$defs": {
    "command": {"oneOf": [{"type": "string", "minLength": 1}, {"type": "array", "minItems": 1, "items": {"type": "string"}}]},
    "ssh": {"type": "object", "required": ["host", "user"], "properties": {"host": {"type": "string", "minLength": 1}, "user": {"type": "string", "minLength": 1}, "port": {"type": "integer", "minimum": 1, "maximum": 65535, "default": 22}, "identityFile": {"type": "string", "minLength": 1}}, "additionalProperties": false},
    "argument": {"type": "object", "required": ["name", "description", "required"], "properties": {"name": {"type": "string", "minLength": 1}, "description": {"type": "string", "minLength": 1}, "required": {"type": "boolean"}, "delimit": {"type": "string", "minLength": 1}, "argName": {"type": "string", "pattern": "^\\S*$"}}, "patternProperties": {"^x-": {}}, "additionalProperties": false},
    "tool": {"type": "object", "required": ["name", "description", "command"], "properties": {"name": {"type": "string", "minLength": 1}, "description": {"type": "string", "minLength": 1}, "command": {"$ref": "#/$defs/command"}, "output": {"enum": ["txt", "yaml", "json", "xml"]}, "arguments": {"type": "object", "propertyNames": {"pattern": "^[A-Za-z_][A-Za-z0-9_]*$"}, "additionalProperties": {"$ref": "#/$defs/argument"}}}, "patternProperties": {"^x-": {}}, "additionalProperties": false}
  }
}
