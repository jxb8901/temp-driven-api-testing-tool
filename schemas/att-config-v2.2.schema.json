{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:att:schema:config:v2.2",
  "type": "object",
  "required": ["schemaVersion"],
  "properties": {
    "schemaVersion": {"const": "att-config/v2.2"},
    "outputDirectory": {"type": "string", "minLength": 1},
    "environment": {"type": "string", "minLength": 1},
    "timeoutMs": {"type": "integer", "minimum": 1, "maximum": 3600000, "default": 10000},
    "templates": {"type": "object", "properties": {"root": {"type": "string", "minLength": 1}}, "patternProperties": {"^x-": {}}, "additionalProperties": false},
    "testcase": {"type": "object", "properties": {"root": {"type": "string", "minLength": 1}}, "patternProperties": {"^x-": {}}, "additionalProperties": false},
    "run": {"type": "object", "properties": {"id": {"type": "object", "properties": {"default": {"const": "timestamp"}, "timestampFormat": {"type": "string", "minLength": 1}}, "patternProperties": {"^x-": {}}, "additionalProperties": false}}, "patternProperties": {"^x-": {}}, "additionalProperties": false},
    "report": {"type": "object", "properties": {"mode": {"const": "append-to-copy"}, "fileNamePattern": {"type": "string"}, "columns": {"type": "object", "additionalProperties": {"type": "string"}}, "junit": {"type": "object", "properties": {"caseLogEmbedThresholdBytes": {"type": "integer", "minimum": 0, "maximum": 1048576}}, "patternProperties": {"^x-": {}}, "additionalProperties": false}}, "patternProperties": {"^x-": {}}, "additionalProperties": false},
    "caseLog": {"type": "object", "properties": {"yamlAnchors": {"type": "boolean", "default": false}}, "patternProperties": {"^x-": {}}, "additionalProperties": false},
    "xml": {"type": "object", "properties": {"namespaceMode": {"enum": ["ignore", "preserve"]}}, "patternProperties": {"^x-": {}}, "additionalProperties": false},
    "toolGroups": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "ssh": {"$ref": "#/$defs/ssh"},
    "tools": {"type": "object", "propertyNames": {"pattern": "^[A-Za-z_][A-Za-z0-9_-]*$"}, "additionalProperties": {"$ref": "#/$defs/tool"}}
  },
  "patternProperties": {"^x-": {}},
  "additionalProperties": false,
  "$defs": {
    "command": {"oneOf": [{"type": "string", "minLength": 1}, {"type": "array", "minItems": 1, "items": {"type": "string"}}]},
    "ssh": {"type": "object", "required": ["host", "user"], "properties": {"host": {"type": "string", "minLength": 1}, "user": {"type": "string", "minLength": 1}, "port": {"type": "integer", "minimum": 1, "maximum": 65535, "default": 22}, "identityFile": {"type": "string", "minLength": 1}}, "additionalProperties": false},
    "argument": {"type": "object", "required": ["name", "description", "required"], "properties": {"name": {"type": "string", "minLength": 1}, "description": {"type": "string", "minLength": 1}, "required": {"type": "boolean"}, "delimit": {"type": "string", "minLength": 1}}, "patternProperties": {"^x-": {}}, "additionalProperties": false},
    "tool": {"type": "object", "required": ["name", "description", "command"], "properties": {"name": {"type": "string", "minLength": 1}, "description": {"type": "string", "minLength": 1}, "command": {"$ref": "#/$defs/command"}, "output": {"enum": ["txt", "yaml", "json", "xml"]}, "arguments": {"type": "object", "propertyNames": {"pattern": "^[A-Za-z_][A-Za-z0-9_]*$"}, "additionalProperties": {"$ref": "#/$defs/argument"}}}, "patternProperties": {"^x-": {}}, "additionalProperties": false}
  }
}
