{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:att:schema:tool-group:v2.6",
  "type": "object",
  "required": ["schemaVersion", "id", "name", "description", "tools"],
  "properties": {
    "schemaVersion": {"const": "att-tool-group/v2.6"},
    "id": {"type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_-]*$"},
    "name": {"type": "string", "minLength": 1},
    "description": {"type": "string", "minLength": 1},
    "script": {"$ref": "#/$defs/command"},
    "ssh": {"$ref": "#/$defs/ssh"},
    "tools": {"type": "object", "minProperties": 1, "propertyNames": {"pattern": "^[A-Za-z_][A-Za-z0-9_-]*$"}, "additionalProperties": {"$ref": "#/$defs/tool"}}
  },
  "patternProperties": {"^x-": {}},
  "additionalProperties": false,
  "$defs": {
    "command": {"oneOf": [{"type": "string", "minLength": 1}, {"type": "array", "minItems": 1, "items": {"type": "string"}}]},
    "ssh": {"type": "object", "required": ["host", "user"], "properties": {"host": {"type": "string", "minLength": 1}, "user": {"type": "string", "minLength": 1}, "port": {"type": "integer", "minimum": 1, "maximum": 65535, "default": 22}, "identityFile": {"type": "string", "minLength": 1}}, "additionalProperties": false},
    "argument": {"type": "object", "required": ["name", "description", "required"], "properties": {"name": {"type": "string", "minLength": 1}, "description": {"type": "string", "minLength": 1}, "required": {"type": "boolean"}, "delimit": {"type": "string", "minLength": 1}, "argName": {"type": "string", "pattern": "^\\S*$"}, "argNameMode": {"enum": ["once", "repeat"], "default": "once"}}, "patternProperties": {"^x-": {}}, "additionalProperties": false},
    "tool": {
      "type": "object",
      "required": ["name", "description"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "command": {"$ref": "#/$defs/command"},
        "call": {"type": "string", "minLength": 1, "pattern": "^#\\{[\\s\\S]*\\}$"},
        "cache": {"type": "object", "required": ["scope"], "properties": {"scope": {"enum": ["case", "db"]}}, "additionalProperties": false},
        "output": {"enum": ["txt", "yaml", "json", "xml"]},
        "arguments": {"type": "object", "propertyNames": {"pattern": "^[A-Za-z_][A-Za-z0-9_]*$"}, "additionalProperties": {"$ref": "#/$defs/argument"}}
      },
      "oneOf": [
        {"required": ["command"], "not": {"anyOf": [{"required": ["call"]}, {"required": ["cache"]}]}},
        {"required": ["call"], "not": {"anyOf": [{"required": ["command"]}, {"required": ["output"]}]}}
      ],
      "patternProperties": {"^x-": {}},
      "additionalProperties": false
    }
  }
}
